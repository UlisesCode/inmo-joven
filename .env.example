# Raíz del monorepo. Next.js carga esto vía apps/web/next.config.mjs (dotenv).
#
# --- Base de datos (obligatorio para login y registro) ---
# En Vercel: definí DATABASE_URL (Postgres con pooling para serverless, p. ej. Neon / Supabase + ?pgbouncer=true si aplica).
# Con Docker (npm run docker:up), usá esta URL tal cual:
DATABASE_URL="postgresql://monoambiente:monoambiente_dev@localhost:5432/monoambiente?schema=public"
# O tu propia instancia:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/monoambiente?schema=public"

# Auth.js / NextAuth (Next.js) — generar: openssl rand -base64 32
AUTH_SECRET="cambiar-por-secreto-largo-y-aleatorio"
# Si en Vercel solo tenés NEXTAUTH_SECRET (nombre viejo), Auth.js lo usa como respaldo.
AUTH_URL="http://localhost:3000"
# Vercel Production: AUTH_URL debe coincidir con la URL pública exacta (https + dominio, sin barra final).
# Ej.: AUTH_URL=https://monoambientes.com  (misma clave AUTH_SECRET o NEXTAUTH_SECRET en Preview y Production si compartís cookies; si no, cada entorno su clave).

# API Fastify (opcional para el home con listados reales)
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"
# Producción (Docker / Railway / Fly): la plataforma suele definir PORT.
# CORS: lista separada por comas, sin espacios extra.
# WEB_ORIGIN="https://monoambientes.com,https://tu-app.vercel.app"
# Si el proxy de Next devuelve "fetch failed", probá 127.0.0.1 en lugar de localhost:
API_URL="http://127.0.0.1:4000"
# Opcional: solo si algún código del cliente llamara al API por URL absoluta.
# Listados Tokko (/departamentos-venta, /departamentos-alquiler) usan /api/tokko/listings (proxy) y solo requieren API_URL arriba.
# NEXT_PUBLIC_API_URL="http://localhost:4000"

# Tokko (opcional — npm run mono -- tokko-smoke)
# TOKKO_API_KEY=
# TOKKO_PORTAL_API_KEY=
# Si Node falla con "self signed certificate" al hablar con tokkobroker.com (proxy SSL), solo en desarrollo:
# TOKKO_INSECURE_TLS=1

# Usuario de prueba vía CLI (opcional; si no usás --demo):
# DEV_LOGIN_EMAIL=
# DEV_LOGIN_PASSWORD=
# DEV_LOGIN_NAME=

# Prisma: tras cambios en schema → npm run db:push (o db:migrate)
#
# Arranque (elegí según tu caso):
# · Postgres ya instalado / corriendo (sin Docker): tenés DATABASE_URL en .env → npm run setup:local
# · Sólo usás Postgres vía Docker Desktop: npm run setup:local:docker  (requiere `docker` en PATH)
# Luego: npm run dev   (y opcionalmente npm run dev:api)
