# PostgreSQL (Prisma: migraciones desde packages/database; Next y API leen el mismo valor)
# Copiá este archivo a `.env` en la raíz del monorepo. Los scripts `db:push` / `db:migrate`
# del paquete `@inmo-joven/database` cargan ese `.env` aunque Prisma corra en `packages/database/`.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/inmo_joven?schema=public"

# Auth.js (Next.js) — generar secreto: openssl rand -base64 32
AUTH_SECRET="cambiar-por-secreto-largo-y-aleatorio"
AUTH_URL="http://localhost:3000"

# API Fastify
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"
# URL base del API para que Next (servidor) pida listados al front
API_URL="http://localhost:4000"

# Tokko (opcional)
# TOKKO_API_KEY=
# TOKKO_PORTAL_API_KEY=

# Tras cambios en prisma/schema.prisma:
# npm run db:push   (o db:migrate) con DATABASE_URL configurada
