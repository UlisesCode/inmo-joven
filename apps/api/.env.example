# Copiá las variables desde la raíz del monorepo (.env) o duplicá DATABASE_URL / AUTH_* si corrés solo la API.

# DATABASE_URL=
# API_PORT=4000
# WEB_ORIGIN=http://localhost:3000

# API key de la inmobiliaria en Tokko (solo servidor). Para probar webcontact:
# TOKKO_API_KEY=

# Opcional: reemplazar la key pública de demo del feed de portal
# TOKKO_PORTAL_API_KEY=
